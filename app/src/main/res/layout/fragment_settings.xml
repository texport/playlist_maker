<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/second_background"
    android:orientation="vertical"
    tools:context=".presentation.settings.SettingsFragment">

    <TextView
        style="@style/Text_YS_Bold_24"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:text="@string/settings"
        android:textColor="@color/main_text_color" />

    <include layout="@layout/settings_item_switch" />
    <include layout="@layout/settings_item_share" />
    <include layout="@layout/settings_item_support" />
    <include layout="@layout/settings_item_license" />

</LinearLayout>